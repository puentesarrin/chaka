# App identity / routing (all optional).
TITLE=Chaka
WEBSOCKET_PATH=/ws
# Asset dirs default to the copies bundled inside the package. Override to use
# your own — e.g. the ./static and ./templates that `chaka init` writes.
# STATIC_DIR=./static
# TEMPLATES_DIR=./templates

# Database (SQLAlchemy async URL). Example uses MySQL via aiomysql.
DATABASE_URL=mysql+aiomysql://user:pass@localhost:3306/chaka

# Admin UI credentials (HTTP Basic). CHANGE THESE before exposing the server.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Application log (rotating file handler).
LOG_FILE=./chaka.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

# Optional: push heartbeat to a status-page / uptime monitor (Uptime Kuma,
# Healthchecks.io, BetterStack, …). Leave HEARTBEAT_URL blank to disable.
HEARTBEAT_URL=
HEARTBEAT_INTERVAL=60
HEARTBEAT_LOG_FILE=./heartbeat.log

# Optional: Sentry error reporting. Leave SENTRY_DSN blank to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
